.env
.env.local
*.local

# Logs
*.log
logs/
log/

# OS
.DS_Store
Thumbs.db

# Node (如未來引入)
node_modules/

# 專案特定
*_bundle.txt
*_bundle_*.txt
.version_manager.json
更新檔/
